# Base path Vite builds asset URLs against. No custom domain is attached yet,
# so the real deployment is https://crossgozon.github.io/maxie-apps-homepage/
# and this must stay "/maxie-apps-homepage/". Change to "/" only once a
# custom domain (a public/CNAME file) is added for this repo.
VITE_BASE_PATH=/maxie-apps-homepage/
