# Base path Vite builds asset URLs against. The real deployment now serves
# from the custom domain www.maxie-apps.online (see public/CNAME), so
# production builds (the GitHub Actions workflow) use "/". This local
# default stays at the GitHub Pages project subpath only as a fallback
# example for testing that specific case; local dev itself always serves
# from root regardless of this value.
VITE_BASE_PATH=/maxie-apps-homepage/

# "owner/repo" GitHub source used for release fetching, and (MaxMacro only,
# for now) the legal doc raw file links on the About page. Defaults to the
# real repos below if unset.
VITE_MAXCLICKER_REPO=crossgozon/maxclicker-download
VITE_MAXMACRO_REPO=crossgozon/maxmacro-download

# Public remote config JSON used for download metadata before falling back
# to GitHub Releases API. Both apps' /api/remote-config endpoints now serve
# public wildcard CORS (D1-cached, includes release date/size), so both point
# at the Worker API rather than a static raw GitHub file.
VITE_MAXCLICKER_REMOTE_CONFIG_URL=https://api.maxie-apps.online/api/remote-config
VITE_MAXMACRO_REMOTE_CONFIG_URL=https://api.maxmacro.maxie-apps.online/api/remote-config

# Legal doc templates (maxmacro-download/legal/*.txt) ship as reusable
# {{PLACEHOLDER}} templates, not filled-in text - DocModal substitutes
# these values in client-side after fetching the raw file, so changing a
# value here doesn't require touching the other repo at all.
VITE_LEGAL_DEVELOPER_ALIAS=MAXIE
VITE_LEGAL_WEBSITE=maxie-apps.online
VITE_LEGAL_SUPPORT_EMAIL=support@maxie-apps.online
VITE_LEGAL_EFFECTIVE_DATE=07/30/2026
VITE_LEGAL_DOCUMENT_VERSION=v1.0.0
